# Generated by LakehousePlumber - Wheel packaging bundle wiring
# Regenerated on every `lhp generate`. Do not edit.
#
# Declares the wheel artifacts LHP builds for wheel-mode pipelines, the UC
# volume they upload to, and a sync-exclude for the `_wheels/` staging dir
# (the wheels reach Databricks as uploaded artifacts, never via file sync).

artifacts:
{% for pipeline in wheel_pipelines %}
  {{ pipeline }}_whl:
    type: whl
    path: generated/{{ env }}/_wheels/{{ pipeline }}
{% endfor %}
targets:
  {{ env }}:
    workspace:
      artifact_path: {{ artifact_path }}

sync:
  exclude:
    - "generated/${bundle.target}/_wheels/**"
