def __lhp_sandbox_table(__lhp_ref):
    """Rewrite an in-scope produced-table reference to its sandbox name.

    Generated by Lakehouse Plumber for a ``--sandbox`` run. Mirrors the static
    matcher exactly: canonicalize the input (lowercase, strip backticks and
    whitespace per dotted part), match the produced set (3-part exact, then the
    2<->3-part short-key rule with the catalog-uniqueness guard), and on a match
    rename the LEAF of the caller's ORIGINAL spelling (preserving casing and
    backticks on every other part). No match returns the input unchanged
    (read-shared semantics); an already-renamed leaf no longer matches, so the
    rewrite is idempotent.
    """
    __lhp_produced = {{ produced_literal }}
    __lhp_short = {{ short_literal }}

    def __lhp_unique(__lhp_key):
        __lhp_cats = __lhp_short.get(__lhp_key)
        if not __lhp_cats or len(__lhp_cats) != 1:
            return None
        __lhp_cat = __lhp_cats[0]
        return (__lhp_cat + "." + __lhp_key) if __lhp_cat else __lhp_key

    __lhp_parts = [
        __lhp_p.replace("`", "").strip().lower() for __lhp_p in __lhp_ref.split(".")
    ]
    if len(__lhp_parts) == 3:
        __lhp_canon = ".".join(__lhp_parts)
        __lhp_match = (
            __lhp_canon
            if __lhp_canon in __lhp_produced
            else __lhp_unique(".".join(__lhp_parts[1:]))
        )
    elif len(__lhp_parts) == 2:
        __lhp_match = __lhp_unique(".".join(__lhp_parts))
    else:
        __lhp_match = None
    if __lhp_match is None:
        return __lhp_ref
    __lhp_orig = __lhp_ref.split(".")
    __lhp_last = __lhp_orig[-1]
    __lhp_leaf = {{ leaf_prefix }} + __lhp_last.replace("`", "").strip() + {{ leaf_suffix }}
    __lhp_orig[-1] = "`" + __lhp_leaf + "`" if "`" in __lhp_last else __lhp_leaf
    return ".".join(__lhp_orig)
