# Unity Catalog Tagging Event Hook — {{ pipeline_name }}
# Generated by Lakehouse Plumber — DO NOT EDIT
# ──────────────────────────────────────────────────────────────────────────────
#
# Applies UC tags to each table (and its columns) as soon as that table's flow
# reaches COMPLETED, via the Entity Tag Assignments REST API.

import os
import json
from concurrent.futures import ThreadPoolExecutor

from pyspark import pipelines as dp

# fqn -> {tag_key: tag_value}
_TABLE_TAGS = {{ table_tags_repr }}

# fqn -> {column_name: {tag_key: tag_value}}
_COLUMN_TAGS = {{ column_tags_repr }}

_TAG_BASE = "/api/2.1/unity-catalog/entity-tag-assignments"
_REMOVE_UNDECLARED_TAGS = {{ remove_undeclared_tags }}

# Tables already tagged in this process — safe because hooks run serially on the driver.
_tagged = set()


def _reconcile_tags(w, entity_type, entity_name, desired):
    """List existing tags then create/update declared ones; delete undeclared
    ones when _REMOVE_UNDECLARED_TAGS is set. Additive otherwise."""
    existing = {}
    query = {}
    while True:
        resp = w.api_client.do(
            "GET", f"{_TAG_BASE}/{entity_type}/{entity_name}/tags", query=query
        )
        for assignment in resp.get("tag_assignments", []):
            existing[assignment["tag_key"]] = assignment.get("tag_value", "")
        next_token = resp.get("next_page_token")
        if not next_token:
            break
        query["page_token"] = next_token

    for key, value in desired.items():
        if key not in existing:
            w.api_client.do(
                "POST",
                _TAG_BASE,
                body={
                    "entity_type": entity_type,
                    "entity_name": entity_name,
                    "tag_key": key,
                    "tag_value": value,
                },
            )
        elif existing[key] != value:
            w.api_client.do(
                "PATCH",
                f"{_TAG_BASE}/{entity_type}/{entity_name}/tags/{key}",
                query={"update_mask": "tag_value"},
                body={
                    "entity_type": entity_type,
                    "entity_name": entity_name,
                    "tag_key": key,
                    "tag_value": value,
                },
            )

    if _REMOVE_UNDECLARED_TAGS:
        for key in existing:
            if key not in desired:
                w.api_client.do(
                    "DELETE",
                    f"{_TAG_BASE}/{entity_type}/{entity_name}/tags/{key}",
                )


def _match_fqn(origin):
    """Resolve the event's flow to a managed fully-qualified table name, or None."""
    managed = set(_TABLE_TAGS) | set(_COLUMN_TAGS)
    candidates = [
        origin.get("dataset_name"),
        origin.get("table_name"),
        origin.get("flow_name"),
    ]
    candidates = [c for c in candidates if c]

    # Exact (fully-qualified) match first.
    for candidate in candidates:
        if candidate in managed:
            return candidate

    # Suffix match for unqualified / 2-part flow names.
    matched = set()
    for candidate in candidates:
        cparts = candidate.split(".")
        for key in managed:
            kparts = key.split(".")
            n = min(len(cparts), len(kparts))
            if n >= 1 and cparts[-n:] == kparts[-n:]:
                matched.add(key)

    if len(matched) == 1:
        return next(iter(matched))
    if len(matched) > 1:
        print(
            f"[LHP Tagging] Ambiguous flow match for {candidates}: "
            f"{sorted(matched)} — skipping"
        )
    return None


def _apply_table(fqn):
    """Reconcile tags for a table and its columns in parallel. Never raises."""
    from databricks.sdk import WorkspaceClient

    w = WorkspaceClient()

    work = []
    if fqn in _TABLE_TAGS:
        work.append(("tables", fqn, _TABLE_TAGS[fqn]))
    for column, tags in _COLUMN_TAGS.get(fqn, {}).items():
        work.append(("columns", f"{fqn}.{column}", tags))

    failures = []

    def _do(item):
        entity_type, entity_name, desired = item
        try:
            _reconcile_tags(w, entity_type, entity_name, desired)
        except Exception as e:  # noqa: BLE001 — best-effort, never fail the hook
            failures.append((entity_name, e))

    with ThreadPoolExecutor(max_workers=max(os.cpu_count() or 1, 8)) as executor:
        list(executor.map(_do, work))

    ok = len(work) - len(failures)
    print(f"[LHP Tagging] {fqn}: reconciled {ok} entity(ies), {len(failures)} failed")
    for entity_name, error in failures:
        print(f"[LHP Tagging]   FAILED {entity_name}: {error}")


@dp.on_event_hook(max_allowable_consecutive_failures=3)
def tagging_hook(event):
    """Tag a table when its flow reaches COMPLETED."""
    if event.get("event_type") != "flow_progress":
        return

    details = event.get("details", {})
    if isinstance(details, str):
        try:
            details = json.loads(details)
        except (ValueError, TypeError):
            return

    if details.get("flow_progress", {}).get("status") != "COMPLETED":
        return

    fqn = _match_fqn(event.get("origin", {}))
    if not fqn or fqn in _tagged:
        return

    _tagged.add(fqn)
    _apply_table(fqn)
