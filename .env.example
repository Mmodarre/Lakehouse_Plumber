# =============================================================================
# LHP Docker Development Environment
# Copy this file to .env and fill in the values below.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED: Path to your local LHP project
# ---------------------------------------------------------------------------
# The directory must contain an lhp.yaml configuration file.
# This is mounted read-only into the container at /project.
LHP_PROJECT_PATH=/path/to/your/lhp-project

# ---------------------------------------------------------------------------
# AI Assistant (OpenCode) — optional but recommended
# ---------------------------------------------------------------------------
# Databricks Model Serving endpoint (must include https://)
# Example: https://adb-1234567890.11.azuredatabricks.net/serving-endpoints/anthropic
ANTHROPIC_BASE_URL=

# Databricks Personal Access Token (used as Bearer token)
ANTHROPIC_AUTH_TOKEN=

# SDK placeholder — required by the Anthropic SDK but not used for actual auth.
# The real authentication uses ANTHROPIC_AUTH_TOKEN as a Bearer token.
ANTHROPIC_API_KEY=unused

# ---------------------------------------------------------------------------
# Optional settings (defaults shown)
# ---------------------------------------------------------------------------
# AI model identifier (provider/model-slug)
# LHP_AI_MODEL=anthropic/databricks-claude-sonnet-4-6

# Host port for the web UI
# LHP_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LHP_LOG_LEVEL=INFO

# OpenCode subprocess port (inside the container)
# LHP_OPENCODE_PORT=4096
